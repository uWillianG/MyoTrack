# Copie para .env e preencha com valores reais antes do deploy.
ASPNETCORE_ENVIRONMENT=Production
POSTGRES_PASSWORD=troque-esta-senha
JWT_SIGNING_KEY=gere-uma-chave-aleatoria-com-no-minimo-48-caracteres
MINIO_ROOT_USER=myotrack
MINIO_ROOT_PASSWORD=troque-esta-senha
FRONTEND_ORIGIN=https://seu-dominio.com.br
# Origem que o browser usa para upload/playback de midia (URLs pre-assinadas via Caddy).
MEDIA_PUBLIC_ENDPOINT=https://seu-dominio.com.br
# Provider de LLM: "anthropic" ou "gemini". Vazio = autodetecta pela chave preenchida
# (Anthropic tem precedência se ambas). Sem nenhuma chave = só motor de regras.
LLM_PROVIDER=
# Chave da API da Anthropic (geração de treino/dieta via LLM). Vazio = só motor de regras.
ANTHROPIC_API_KEY=
# Modelo Claude. claude-opus-4-8 (melhor qualidade) ou um modelo mais barato se o custo apertar.
LLM_MODEL=claude-opus-4-8
# Chave da API do Google Gemini (crie em https://aistudio.google.com/apikey).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Stripe (billing). Vazio = pagamentos desabilitados, todos ficam no plano gratuito.
# Webhook: aponte para https://seu-dominio/api/billing/webhook com os eventos
# checkout.session.completed, customer.subscription.updated e customer.subscription.deleted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
