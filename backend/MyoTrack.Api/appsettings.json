{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=myotrack;Username=myotrack;Password=dev-only-password"
  },
  "Jwt": {
    "Issuer": "MyoTrack",
    "Audience": "MyoTrack",
    "SigningKey": "dev-only-signing-key-change-me-in-production-0123456789",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "myotrack",
    "SecretKey": "dev-only-password",
    "Bucket": "myotrack-media"
  },
  "Limits": {
    "MaxMealAnalysesPerDay": 10,
    "MaxVideoAnalysesPerDay": 5
  }
}
