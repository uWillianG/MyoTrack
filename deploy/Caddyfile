# Em produção, troque :80 pelo domínio (ex.: myotrack.com.br) para TLS automático.
:80 {
	encode gzip

	handle /api/* {
		reverse_proxy api:8080
	}

	handle /health {
		reverse_proxy api:8080
	}

	# URLs pré-assinadas do MinIO (path-style): o caminho /myotrack-media/*
	# precisa chegar intacto ao MinIO para a assinatura conferir.
	handle /myotrack-media/* {
		reverse_proxy minio:9000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
